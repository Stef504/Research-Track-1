void timer_callback()
 { 
  // Enforce a short initial forward period so the turtle doesn't
  // immediately trigger "near center" behavior at spawn.
  if (!initial_move_done_) {
    ++tick_count_;
    message.linear.x = 1.0;
    message.angular.z = 0.0;
    publisher_->publish(message);
    if (tick_count_ >= ticks_initial_forward) {
      initial_move_done_ = true;
    }
    return; // Exit here when initial_move_done=true
  }


  // Use absolute difference for center detection
  if (std::fabs(x_ - CENTER_X) < tol && std::fabs(y_ - CENTER_Y) < tol) {
    
    if (!_move_done_){
      ++count_;
      message.linear.x = 0.0;
      message.angular.z = ROTATION_SPEED; // rotate while publishing
      publisher_->publish(message);
    
    if (count_ >= ticks_needed) {
      _move_done_ = true;
      count_=0;
    }
    return; // Exit here so we don't try to drive forward in the same tick
    }
    
  // 3. If we ARE done rotating (the code only reaches here if _move_done_ is true)
  // Now we drive forward
  message.linear.x = 1.0;
  message.angular.z = 0.0;
}else {
    // --- WE ARE OUTSIDE THE CENTER ---
    
    // We have left the center, so we "re-arm" the rotation for next time.
    _move_done_ = false; 
    count_ = 0;
  if (x_ > 10.5) {
    message.linear.x = -1.0;
    message.angular.z = 0.0;
  }
  else if (x_ < 1.0) {
    message.linear.x = -1.0;
    message.angular.z = 0.0;
  }
  else if (y_ > 10.5) {
    message.linear.x = -1.0;
    message.angular.z = 0;
  }
  else if (y_ < 1.0) {
    message.linear.x = -1.0;
    message.angular.z = 0.0;
  }
}
  publisher_->publish(message);
 
}

 rclcpp::Subscription<turtlesim::msg::Pose>::SharedPtr subscription;
 rclcpp::Publisher<geometry_msgs::msg::Twist>::SharedPtr publisher_;
 rclcpp::TimerBase::SharedPtr timer_;
 geometry_msgs::msg::Twist message;
 double x_ = 0.0, y_ = 0.0; 
  // initial-move state to avoid triggering center behavior at spawn
  // number of timer ticks to move forward initially
  int tick_count_ = 0;
  int count_ =0;
  bool initial_move_done_ = false;
  bool _move_done_ = false;
  // workspace bounds (turtlesim default)
  const double MIN_X = 1.0;
  const double MAX_X = 11.0;
  const double MIN_Y = 1.0;
  const double MAX_Y = 11.0;
  const double CENTER_X = 5.5;
  const double CENTER_Y = 5.5;

  //the purpose of const is to tell the compiler these values won't change even 
  //if they are used multiple times
  const double tol=0.2; //tolerance for center detection
  const double TARGET_ANGLE = 1.57; // 90 degrees in radians
  const double ROTATION_SPEED = 1.5; // rad/s
  const double LOOP_RATE = 5; // Change this to match your actual Hz
  const double INITIAL_FORWARD_SPEED = 1.0; // Initial forward speed
  const double TARGET_DISTANCE =1.0;

  // Calculate required ticks (Integers)
  // (Target / Speed) * Rate
  int ticks_needed = static_cast<int>((TARGET_ANGLE / ROTATION_SPEED) * LOOP_RATE);
  int ticks_initial_forward = static_cast<int>((TARGET_DISTANCE / INITIAL_FORWARD_SPEED) * LOOP_RATE);